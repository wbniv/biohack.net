# Cloudflare Pages cache rules.
# HTML pages: always revalidate — fresh ETags after each deploy, no stale page state.
# /play/* assets: immutable — app.js bust() always appends ?v=<sha>, so bare URLs are never
# used in practice; safe to cache forever and avoids 304 round-trips for the 4 MB WASM core.
/*
  Cache-Control: public, max-age=0, must-revalidate

/play/*
  Cache-Control: public, max-age=31536000, immutable
