---
import Base from '../layouts/Base.astro';
---
<Base>
  <style>
    /* ── Header ─────────────────────────────────────────── */
    #site-header {
      margin-top: 32px;
      padding: 8px 0 28px;
      margin-bottom: 8px;
    }
    #site-header h1 {
      margin: 0;
      font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif;
      font-weight: 400;
      font-size: clamp(28px, 8vw, 44px);
      letter-spacing: 0.04em;
      color: var(--ink);
      line-height: 1;
      text-transform: uppercase;
    }
    #site-header h1 strong {
      color: var(--accent);
      font-weight: 400;
      padding: 0 2px;
      font-size: 1.6em;
      line-height: 0.5;
      vertical-align: -0.02em;
      display: inline-block;
    }

    /* ── Section heads ───────────────────────────────────── */
    section { margin-top: 48px; }
    section > h1 {
      margin: 0 0 22px;
      font-weight: 600;
      font-size: 12px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #7dd3fc;
      border: none;
      padding: 0;
    }

    /* ── Profile ─────────────────────────────────────────── */
    .columns {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: start;
    }
    @media (min-width: 640px) {
      .columns { gap: 32px; }
    }
    .columns > p {
      margin: 0;
      font-size: 15.5px;
      line-height: 1.7;
      color: var(--ink);
      max-width: 62ch;
    }

    /* ── Link tiles ──────────────────────────────────────── */
    .columns ul {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      grid-template-columns: repeat(2, 84px);
      gap: 8px;
    }
    @media (min-width: 640px) {
      .columns ul { grid-template-columns: repeat(2, 110px); }
    }
    .columns ul li {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      padding: 14px 14px 12px;
      border: 1px solid var(--rule);
      background: var(--bg-soft);
      aspect-ratio: 1 / 1;
      transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .columns ul li:hover {
      background: rgba(125,211,252,0.05);
      border-color: #7dd3fc;
      box-shadow: 0 0 20px rgba(125,211,252,0.5), 0 0 40px rgba(125,211,252,0.2);
    }
    .columns ul li::before {
      content: '';
      position: absolute;
      top: 8px; right: 10px;
      width: 5px; height: 5px;
      border-top: 1px solid var(--ink-dim);
      border-right: 1px solid var(--ink-dim);
      transform: rotate(45deg);
      opacity: 0.45;
      transition: border-color 0.15s, opacity 0.15s, transform 0.15s;
    }
    .columns ul li:hover::before {
      border-color: var(--accent);
      opacity: 1;
      transform: rotate(45deg) translate(2px, -2px);
    }
    .columns ul svg.icon {
      display: block;
      width: 22px;
      height: 22px;
      flex: none;
      stroke: var(--ink);
      stroke-width: 1.4;
      transition: stroke 0.15s;
    }
    .columns ul li:hover svg.icon { stroke: var(--accent); }
    .columns ul a {
      color: var(--ink);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: -0.01em;
      transition: color 0.15s;
    }
    .columns ul li:hover a { color: var(--accent); }

    /* ── Projects ────────────────────────────────────────── */
    #projects > p {
      margin: 0 0 22px;
      font-size: 15px;
      line-height: 1.7;
      color: var(--ink);
      max-width: 62ch;
    }
    #projects ul {
      list-style: none;
      padding: 0;
      margin: 0;
      counter-reset: proj;
    }
    #projects ul li {
      position: relative;
      padding: 12px 0 12px 44px;
      font-size: 17px;
      line-height: 1.6;
      counter-increment: proj;
    }
    #projects ul li::before {
      content: counter(proj, decimal-leading-zero);
      position: absolute;
      left: 0; top: 15px;
      font-size: 11px;
      color: #7dd3fc;
      letter-spacing: 0.1em;
      font-weight: 600;
      padding: 2px 8px;
      border: 1px solid rgba(125,211,252,0.45);
      border-radius: 2px;
      background: rgba(125,211,252,0.10);
    }
    #projects a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px dotted rgba(194,65,12,0.5);
      transition: border-color 0.15s, background 0.15s;
      padding-bottom: 1px;
    }
    #projects a:hover {
      border-bottom-style: solid;
      background: var(--accent-bg);
    }
    .narrow-only { display: none; }
    @media (max-width: 600px) {
      .wide-only { display: none; }
      .narrow-only { display: inline; }
    }

    /* ── Blockquote — Blade Runner treatment ─────────────── */
    blockquote {
      margin: 56px 0 0;
      padding: 36px 36px 28px;
      border: 1px solid rgba(255,140,0,0.15);
      font-size: 18px;
      line-height: 1.6;
      font-style: italic;
      color: var(--ink);
      position: relative;
      overflow: hidden;
      background: linear-gradient(
        160deg,
        rgba(255,100,0,0.06) 0%,
        rgba(20,12,4,0.5) 60%
      );
      box-shadow: 0 0 24px rgba(255,120,0,0.1), inset 0 0 40px rgba(255,80,0,0.03);
    }
    /* corner reticles — top-left, top-right, bottom-left, bottom-right */
    blockquote::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        /* scanlines */
        repeating-linear-gradient(
          0deg,
          transparent, transparent 3px,
          rgba(0,0,0,0.14) 3px, rgba(0,0,0,0.14) 4px
        );
      pointer-events: none;
      z-index: 0;
    }
    blockquote > * { position: relative; z-index: 1; }
    /* neon quote character */
    blockquote::after {
      content: '\201C';
      position: absolute;
      top: -24px; left: 18px;
      font-family: Georgia, serif;
      font-size: 140px;
      line-height: 1;
      font-style: normal;
      color: #ff8c00;
      text-shadow:
        0 0 8px rgba(255,140,0,0.9),
        0 0 20px rgba(255,100,0,0.6),
        0 0 50px rgba(255,60,0,0.3);
      pointer-events: none;
      z-index: 0;
      opacity: 0.55;
    }
    /* corner bracket decoration via outline divs — using box-shadow trick on blockquote corners */
    blockquote .corner-tl, blockquote .corner-tr,
    blockquote .corner-bl, blockquote .corner-br {
      position: absolute;
      width: 18px; height: 18px;
      z-index: 2;
    }
    blockquote .corner-tl { display: none; }
    blockquote .corner-tr { top: 0; right: 0;
      border-top: 2px solid #7dd3fc; border-right: 2px solid #7dd3fc;
      box-shadow: 2px -2px 8px rgba(125,211,252,0.5); }
    blockquote .corner-bl { bottom: 0; left: 0;
      border-bottom: 2px solid #7dd3fc; border-left: 2px solid #7dd3fc;
      box-shadow: -2px 2px 8px rgba(125,211,252,0.5); }
    blockquote .corner-br { display: none; }
    blockquote cite {
      display: block;
      margin-top: 16px;
      font-style: normal;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #ff8c00;
      font-family: 'JetBrains Mono', monospace;
      opacity: 0.75;
    }

    /* ── Prompt ──────────────────────────────────────────── */
    .prompt {
      margin-top: 48px;
      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 13px;
      color: var(--ink-dim);
      letter-spacing: 0.04em;
    }
    .prompt .blink {
      display: inline-block;
      width: 8px; height: 14px;
      background: var(--accent);
      vertical-align: -2px;
      margin-left: 6px;
      animation: blink 1.05s steps(1, end) infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }
  </style>

  <header id="site-header">
    <h1>bioHACK <strong>•</strong> NET</h1>
  </header>

  <section id="profile">
    <h1>Profile</h1>
    <div class="columns">
      <p>Will is a hacker and professional software developer with a profound interest in wiki and social collaboration, process management, realtime simulation, and data visualization.</p>
      <ul>
        <li>
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><line x1="8" y1="9" x2="10" y2="9"/></svg>
          <a href="/cv/">C.V.</a>
