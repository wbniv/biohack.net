---
// /3d-wireframe — playable in-browser wireframe 3-D solid SNES demo + instructions.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/3d-wireframe.sfc.
// Spins a tetrahedron / cube / octahedron / icosahedron into a 2bpp bitmap canvas —
// SNES demo #16 of the llvm-mos-65816 compiler stress-test battery.
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/3d-wireframe.sfc', 'preview/3d-wireframe.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

// In-browser keys (fixed by the player) -> wireframe 3-D actions.
const controls = [
  ['↑ / ↓', 'Speed Y-axis  + / −'],
  ['← / →', 'Speed X-axis  + / −'],
  ['Q / W', 'Dolly distance  − / +'],
  ['A / X', 'Previous / next solid (tetra → cube → octa → icosa)'],
  ['S', 'Cycle palette'],
  ['Shift', 'Toggle trail / crisp'],
  ['Enter', 'Reset'],
];

const solids = [
  ['TETRA', '4 faces, 4 vertices, 6 edges — the simplest solid'],
  ['CUBE', '6 faces, 8 vertices, 12 edges — a plain box in 3-D'],
  ['OCTA', '8 faces, 6 vertices, 12 edges — two square pyramids joined'],
  ['ICOSA', '20 faces, 12 vertices, 30 edges — the most complex'],
];
---

<Base title="Wireframe 3-D Solid — bioHACK•NET" description="A spinning wireframe polyhedron (tetrahedron, cube, octahedron, icosahedron) rendered live on the Super Nintendo in C — a compiler stress-test for the llvm-mos 65816 toolchain. Play it in your browser.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Wireframe 3-D Solid</h1>
      <a href="/snes/#cat-physics" class="rp-cat-chip">Physics &amp; Simulation</a>
      <p class="rp-lede">
        A spinning polyhedron drawn live on the Super Nintendo — tetrahedron, cube, octahedron,
        icosahedron. Each frame builds a 3×3 rotation matrix (three <em>Q8.8</em> matrix multiplies),
        projects every vertex through a perspective divide, and connects the edges with integer
        Bresenham lines into a 2bpp bitmap canvas. Written in C and compiled to a real
        <code>.sfc</code> ROM with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code> 16-bit accumulator). Demo #16 of the compiler stress-test battery.
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Wireframe 3-D Solid">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">
        <b>↑</b>/<b>↓</b> spin Y · <b>←</b>/<b>→</b> spin X · <b>Q</b>/<b>W</b> dolly ·
        <b>X</b>/<b>A</b> solid · <b>S</b> palette · <b>Shift</b> trail · <b>Enter</b> reset
      </p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen, then play. Switch solids with <kbd>X</kbd>/<kbd>A</kbd>; toggle trail mode with <kbd>Shift</kbd>.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>Controls</h2>
      <table class="rp-table">
        <thead><tr><th>Keys</th><th>Action</th></tr></thead>
        <tbody>{controls.map(([k, a]) => (<tr><td><kbd>{k}</kbd></td><td>{a}</td></tr>))}</tbody>
      </table>

      <h2>The four solids</h2>
      <p>Cycle them with <kbd>A</kbd> (previous) / <kbd>X</kbd> (next). Each has its own
        vertex count and edge table — the icosahedron has 30 edges to draw per frame.</p>
      <table class="rp-table rp-wide">
        <thead><tr><th>Solid</th><th>What it is</th></tr></thead>
        <tbody>{solids.map(([n, d]) => (
          <tr><td class="rp-mono">{n}</td><td>{d}</td></tr>
        ))}</tbody>
      </table>

      <h2>Rendering modes</h2>
      <p><kbd>Shift</kbd> toggles between two modes shown in the top-right HUD:</p>
      <ul>
        <li><b>TRAIL</b> — phosphor accumulate: lines are never erased, leaving a luminous ghost.
          Try spinning fast then slow — the solid unpeels itself from its own trail.</li>
        <li><b>CRISP</b> — canvas clears each frame before redrawing: a clean, sharp rotation.</li>
      </ul>

      <h2>Tips</h2>
      <ul>
        <li><b>Set spin to zero</b> with <kbd>↑</kbd>/<kbd>↓</kbd> and <kbd>←</kbd>/<kbd>→</kbd>
          to freeze the solid — then step it slowly.</li>
        <li><b>Dolly in</b> (<kbd>Q</kbd>) until the camera is almost inside the solid; the
          perspective distortion becomes extreme on the icosahedron.</li>
        <li><b>It's a compiler stress-test.</b> The mat3_mul loop calls <code>__mulsi3</code> (32-bit
          software multiply) nine times per matrix element; the perspective divide calls
          <code>__divsi3</code>. Under <code>+mos-a16</code> the 65816 runs in native
          16-bit-accumulator mode, so the mode-switch <code>rep</code>/<code>sep</code> pairs bracket
          every multiply.</li>
      </ul>

      <p class="rp-foot">Written in C with an LLVM/65816 SNES toolchain. The 3-D math — matrix
        multiply + perspective divide — runs identically on the host oracle and all three compiler
        modes, verified against MAME and bsnes-jg. Hit <b>Verify fidelity</b> to reproduce the
        build gate's WRAM assert (3-D math hash <code>0xEF8E</code>) live in this tab. No far
        pointers, so the same program is checked five ways: host == default == <code>+mos-a16</code>
        == <code>+mos-xy16</code>.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = '3d-wireframe';
    window.BJG_BUST = bust;
    window.BJG_SELFCHECK = { off: 0x136a, len: 2, want: 0xEF8E, frames: 300, label: '3-D math hash' };
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-cat-chip {
    display: inline-block; margin-top: .5rem; padding: 3px 10px;
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-dim); background: var(--bg-soft, #1e2128);
    border: 1px solid var(--rule, #2e3138); border-radius: 4px;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .rp-cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a { color: var(--accent); text-decoration: none; }
  .rp-lede a:hover { text-decoration: underline; }

  /* player — CENTRED, capped near 2x native */
  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0;
               border: 1px solid var(--rule); }
  /* NATURAL aspect, no overflow:hidden / object-fit (which would shave the top scanline). */
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.running { color: var(--accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); }
  .rp-keys b { color: var(--ink); font-weight: 600; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner :global(b) { color: var(--ink); }
  .rp-banner :global(code) { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }

  /* instructions */
  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc ul { margin: .4rem 0; padding-left: 1.2rem; }
  .rp-doc li { margin: .35rem 0; }
  .rp-doc b { color: var(--ink); }
  .rp-doc a { color: var(--accent); text-decoration: none; }
  .rp-doc a:hover { text-decoration: underline; }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-table { width: 100%; max-width: 26rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 34rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .68rem; letter-spacing: .08em;
                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .rp-doc kbd { font: 600 .82em 'JetBrains Mono', ui-monospace, monospace; color: var(--ink);
                border: 1px solid var(--rule); border-radius: 4px; padding: .05em .4em; background: var(--bg-soft); }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
