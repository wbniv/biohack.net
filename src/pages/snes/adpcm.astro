---
// /snes/adpcm — playable in-browser ADPCM Waverider SNES demo.
// Compiler stress-test #89: IMA-ADPCM saturating predictor feedback (G_SADDSAT/G_SSUBSAT).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/adpcm.sfc', 'preview/adpcm.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `// IMA-ADPCM: predictor updated with SATURATING add/sub, inside a serial feedback loop.
int16_t decode(uint8_t n) {
  int16_t step = STEP[idx];
  int32_t diff = step>>3;
  if (n&4) diff+=step; if (n&2) diff+=step>>1; if (n&1) diff+=step>>2;
  pred = (n&8) ? __builtin_elementwise_sub_sat(pred, diff)   // G_SSUBSAT
               : __builtin_elementwise_add_sat(pred, diff);  // G_SADDSAT
  idx += IDX[n]; clamp(idx, 0, 88);   // step-size LUT walk
  return pred;                         // next output depends on THIS pred (feedback)
}`;

const notes = [
  ['saturating feedback', 'The predictor is clamped every sample with __builtin_elementwise_add_sat/_sub_sat (G_SADDSAT/G_SSUBSAT) so a loud passage rails at ±full-scale instead of wrapping to the opposite sign — a decode wrap would be an audible click. The clamp is inside a serial recurrence, so a miscompiled saturate would corrupt the entire rest of the waveform.'],
  ['serial recurrence', 'Each output sample is pred += ±diff of the previous sample — a true feedback loop that cannot be vectorized or reordered. The step size also walks an 89-entry table indexed by a running state updated every nibble.'],
  ['host vs target', 'The host oracle (gcc) has no elementwise saturating builtins and uses a bit-identical manual clamp; the 65816 target (clang) uses the real intrinsics. The differential gate confirms both produce the same waveform CRC.'],
  ['distinct from #48 / #67', '#48 IIR is a wrapping fixed-point feedback filter (no saturation). #67 huffman has no feedback at all. This is the saturating-arithmetic-in-a-feedback-loop member of the battery.'],
];
---

<Base title="ADPCM Waverider — bioHACK•NET" description="An IMA-ADPCM audio decoder on a Super Nintendo — a saturating predictor in a serial feedback loop with a step-size LUT walk, drawn as a scrolling oscilloscope. Compiler stress-test #89.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">ADPCM Waverider</h1>
      <a href="/snes/#cat-algorithms" class="rp-cat-chip">Algorithms &amp; Numeric</a>
      <p class="rp-lede">
        An <a href="https://en.wikipedia.org/wiki/Adaptive_differential_pulse-code_modulation">IMA-ADPCM</a>
        audio decoder — the compression used by countless game samples. Each 4-bit code nudges a
        <b>predictor</b> that is clamped with <b>saturating</b> add/sub (<code>G_SADDSAT</code>/
        <code>G_SSUBSAT</code>), and the step size walks an 89-entry table. It's a true
        <b>serial feedback loop</b>: every sample depends on the last. Drawn as a scrolling
        oscilloscope. Compiler stress-test #89.
      </p>
    </header>

    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running ADPCM Waverider">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running — a decoded ADPCM waveform scrolls across the scope.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A pseudo-random 4-bit ADPCM code stream is decoded into a 16-bit waveform and plotted
        across the scope. Because the predictor accumulates, the trace wanders and then rails
        against the saturation limits at the top and bottom — exactly where the saturating add/sub
        keeps it from wrapping into a glitch.
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        The feedback recurrence is the hard part for a compiler: the saturating clamp sits on the
        critical path of a loop that can't be reordered, so the backend must get both the
        saturating opcode and the dependency chain right. The host oracle checks the decoded
        waveform is bit-identical.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against
        bsnes-jg and MAME. Hit <b>Verify fidelity</b> to reproduce the build gate's WRAM assert
        (ADPCM CRC <code>0xCA56</code> — a fold of the decoded predictor stream) live in this tab.
        No far pointers — <code>host == default == +mos-a16 == +mos-xy16</code>,
        <code>-verify</code> clean.</p>
    </section>
  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'adpcm';
    window.BJG_BUST = bust;
    window.BJG_SELFCHECK = { off: 0x67, len: 2, want: 0xCA56, frames: 500, label: 'adpcm CRC' };
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

