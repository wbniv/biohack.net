---
// /snes/bitshuffle — playable in-browser Perfect-Shuffle Transition SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/bitshuffle.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/bitshuffle.sfc', 'preview/bitshuffle.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `perm(i) = bitreverse32(i) >> 24;   // reverse the low 8 bits
// bit-reversal is its own inverse:
perm(perm(i)) == i;                 // scramble == unscramble
// hold-phase recolour:
c = bswap32(token) & 3;             // swap the four bytes`;

const notes = [
  ['bit-reverse intrinsic', '__builtin_bitreverse32 — reverse every bit of a 32-bit word. The 65816 has no such instruction, so the backend expands it inline into a mask-swap cascade (swap adjacent bits, then pairs, then nibbles, then bytes). The complementary masks 0xAAAA / 0xCCCC / 0xF0F0 are visible in the disassembly.'],
  ['byte-swap intrinsic', '__builtin_bswap32 — reverse the four bytes of a word (the endian-flip you\'d use to read big-endian data). It lowers to a few byte moves, and recolours the image while it\'s held scrambled.'],
  ['an involution', 'Reversing the bits of an index twice gives it back, so a single operation both scrambles the picture into its "butterfly" order and puts it back — the perfect (riffle) shuffle from the FFT.'],
  ['hand-rolled vs builtin', 'Two earlier demos (an FFT and a Hilbert curve) reverse bits by hand in a shift loop. This one calls the compiler intrinsics instead, exercising a code path — generic opcode to legalizer — that the hand-written loops never reach. It stays bit-exact across every codegen mode.'],
];
---

<Base title="Perfect-Shuffle Transition — bioHACK•NET" description="An image scrambles into its bit-reversed 'butterfly' order and reassembles on a Super Nintendo, driven by the __builtin_bitreverse32 and __builtin_bswap32 intrinsics. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Perfect Shuffle</h1>
      <a href="/snes/#cat-ciphers" class="rp-cat-chip">Ciphers &amp; Bit Tricks</a>
      <p class="rp-lede">
        An image on a Super Nintendo dissolves into its <a href="https://en.wikipedia.org/wiki/Bit-reversal_permutation">bit-reversed</a>
        order — the "butterfly" shuffle at the heart of the FFT — and then reassembles, because reversing
        an index's bits <em>twice</em> gives it back. It's driven by two compiler intrinsics:
        <code>__builtin_bitreverse32</code> flips every bit of a word, and <code>__builtin_bswap32</code>
        reverses its four bytes to recolour the picture mid-shuffle. Runs on its own; no joypad needed.
        Written in C and compiled with the <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based
        65816 toolchain (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Perfect-Shuffle Transition">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the image scrambles and reassembles on its own.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A <a href="https://en.wikipedia.org/wiki/Bit-reversal_permutation">bit-reversal permutation</a>
        reorders a list by reversing the bits of each position's index. It shows up in the fast Fourier
        transform, and it has a neat property: apply it twice and you're back where you started.
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        So a single operation both scrambles the picture and unscrambles it. A second intrinsic,
        <code>__builtin_bswap32</code>, reverses the four bytes of a word to shuffle the colours while
        the image is held scrambled. Neither has a matching 65816 instruction, so the compiler expands
        them inline — and the result stays bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0x2A4A</code> — a fold of the full 32-bit bit-reversals and
        byte-swaps over 256 indices) live in this tab. No far pointers — the same source passes every way:
        host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'bitshuffle';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

