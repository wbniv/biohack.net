---
// /snes/buddhabrot — playable in-browser Buddhabrot SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/buddhabrot.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
//
// Cache-busting: hash each play/ asset at build time -> window.BJG_BUST; app.js appends "?v=<sha>"
// so the edge caches immutably yet a re-synced asset still gets a fresh URL.
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/buddhabrot.sfc', 'preview/buddhabrot.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const notes = [
  ['Far scatter-writes', 'The 128×128 hit-count grid is 16 KiB — far past the ~7.7 KiB of low WRAM — so it lives in high WRAM at $7E2000 and every visited orbit point is a far read-modify-write (lda [dp] / inc / sta [dp]) at a runtime-computed index. This is the #320 24-bit far path, only legal under +mos-a16'],
  ['PRNG sampling', 'Each complex sample c is drawn by a 16-bit xorshift generator scaled into the Mandelbrot window with an unsigned 32-bit multiply — deterministic, so host and target agree bit-for-bit'],
  ['Complex multiply ×2 passes', 'Three Q5.10 16×16→32 multiplies (zr², zi², zr·zi) per iteration, run TWICE per sample: once to test escape, once to replay the orbit and deposit it. The gate object holds __mulsi3/__umulsi3'],
  ['rep/sep', 'Native 16-bit accumulator brackets under +mos-a16 — the complex iterands route through the Imag16 zero-page pair as int16; 31 rep / 34 sep across the kernel'],
  ['3-way bar', 'A far pointer is a 32-bit value, so the default 8-bit and +mos-xy16 builds cannot legalize it — the differential is host == +mos-a16 on the cycle-accurate bsnes-jg core'],
];
---

<Base title="Buddhabrot — bioHACK•NET" description="The Buddhabrot: random complex points iterated z²+c, and for those that escape, the whole orbit is accumulated into a density buffer in high SNES WRAM via far scatter-writes — the ghostly probability cloud of the Mandelbrot set. PRNG sampling + far read-modify-write under +mos-a16. Written in C with the llvm-mos 65816 toolchain.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Buddhabrot</h1>
      <p class="rp-lede">
        The <a href="https://en.wikipedia.org/wiki/Buddhabrot">Buddhabrot</a> — the Mandelbrot set's
        ghost. Random complex points <code>c</code> are iterated <code>z ← z² + c</code>; for the ones
        that <em>escape</em>, the entire orbit is replayed and every point it visited is tallied into a
        density buffer. Where escaping orbits linger, the buffer glows — and a smoke-like figure emerges
        from the noise. The 16 KiB grid lives in high WRAM, written by far scatter-stores. Runs
        automatically; the cloud blooms in as samples accumulate. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Buddhabrot">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the density cloud blooms in over ~1–2 minutes.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        The Mandelbrot set colours each <em>pixel</em> by how fast its orbit escapes. The Buddhabrot
        turns that inside out: it forgets where each sample started and instead asks <em>where do
        escaping orbits spend their time?</em> Sample a random <code>c</code>, iterate, and if the orbit
        escapes within a cap, walk it again and increment a counter at every grid cell it touched. The
        accumulated histogram is the Buddhabrot — the probability density of escaping trajectories,
        which traces a translucent, meditating-figure silhouette around the set's boundary:
      </p>
      <pre class="rp-code">for many random c:                  // xorshift16 PRNG
    z = 0
    if iterating z = z²+c escapes within N steps:
        z = 0
        replay N steps, ++grid[map(z)]   // far RMW in high WRAM

draw: grid hit-count → CGRAM brightness (a ghostly glow ramp)</pre>
      <p>
        On screen the brightest regions are where many escaping orbits cross; the faint blue haze is the
        sparse outer density. The image is top-bottom symmetric (the set is symmetric about the real
        axis) — a free correctness check on the math.
      </p>

      <h2>Compiler stress-test #4 — PRNG + far scatter-writes</h2>
      <p>
        Most fractals in this gallery write each pixel once, in order. The Buddhabrot <em>scatters</em>
        writes all over a buffer too big for low WRAM — so it is the gallery's <em>far scatter-write</em>
        member, the one demo whose hot loop hammers the 24-bit far read-modify-write path the rest only
        touch lightly:
      </p>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p>
        The Buddhabrot logic is a portable C header (<code>examples/65816/buddha.h</code>) linked into
        the SNES ROM and a host oracle alike — the same body compiled with 32-bit <code>int</code> on the
        host and 16-bit <code>int</code> on the 65816. The gate asserts <code>corpus_result</code> — a
        16-bit rotate-XOR hash over the whole density grid after a fixed-seed accumulation — is identical
        on both.
      </p>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain. Hit <b>Verify fidelity</b> to
        reproduce the build gate's WRAM assert (gate hash <code>0x7C31</code>) live in this tab — the
        same hash the host oracle and the cycle-accurate bsnes-jg core agree on for the
        <code>+mos-a16</code> far-pointer build.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'buddhabrot';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }
  .rp-lede em { font-style: italic; }

  /* player — CENTRED, capped near 2x native */
  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0;
               border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.running { color: var(--accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); font-style: italic; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner :global(b) { color: var(--ink); }
  .rp-banner :global(code) { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }

  /* instructions */
  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc em { font-style: italic; }
  .rp-doc b { color: var(--ink); }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
             background: var(--bg-soft, #1e2128); color: var(--accent); padding: .75rem 1rem;
             border-radius: 6px; margin: .75rem 0; white-space: pre; overflow-x: auto; line-height: 1.6; }
  .rp-table { width: 100%; max-width: 26rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 44rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .68rem; letter-spacing: .08em;
                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .85em; }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
