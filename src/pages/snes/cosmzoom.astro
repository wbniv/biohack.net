---
// /snes/cosmzoom — playable in-browser Cosmic Zoom Ruler SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/cosmzoom.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/cosmzoom.sfc', 'preview/cosmzoom.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `uint64_t scale = ...;          // grows through the powers of ten
float f = (float)scale;        // __floatundisf : 64-bit int -> float
position = log_ruler(f);       // place it on a log scale
uint64_t back = (uint64_t)f;   // __fixunssfdi : float -> 64-bit int`;

const notes = [
  ['64-bit int to float', 'Turning a 64-bit integer into a floating-point number is a library routine (__floatundisf); turning it back is another (__fixunssfdi). Two earlier float demos only ever converted 32-bit integers — the 64-bit versions are a separate set of routines exercised here for the first time.'],
  ['correctly rounded', 'These conversions are required by the IEEE standard to round to the nearest representable value, so the host and the console must agree to the bit. That makes them a sharp differential test.'],
  ['log ruler', 'A scale growing by a fixed percentage each step is exponential; plotting its logarithm turns that into a steady linear sweep. Converting the 64-bit scale to float is how the log position is computed.'],
  ['no overflow', 'The scale is kept below 10^18 so that rounding it to float can never push it past the 64-bit range on the way back — which would be undefined behaviour. A small discipline that keeps the round-trip well-defined.'],
];
---

<Base title="Cosmic Zoom Ruler — bioHACK•NET" description="A 64-bit scale growing through the powers of ten, placed on a logarithmic ruler by converting it to float — the 64-bit integer to float conversion — on a Super Nintendo. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Cosmic Zoom</h1>
      <p class="rp-lede">
        A number growing from one to a quintillion — <em>nanometres to the cosmos</em> — swept across a
        <a href="https://en.wikipedia.org/wiki/Logarithmic_scale">logarithmic</a> ruler on a Super
        Nintendo. The scale is a 64-bit integer, and placing it on the ruler means converting it to a
        floating-point number: <code>(float)scale</code>. That 64-bit-integer-to-float conversion — and
        the trip back — is the point. Exponential growth becomes a steady linear sweep. Runs on its own;
        no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Cosmic Zoom Ruler">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the bar sweeps as the scale climbs the powers of ten.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        Computers store whole numbers and floating-point numbers very differently, and converting between
        them is real work — a routine, not a single instruction, especially for 64-bit integers on an
        8/16-bit CPU:
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        The ruler is logarithmic, so each power of ten is an equal step and the exponentially-growing
        scale slides across at a constant pace. The conversion to float is exactly how its position is
        found. It stays bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0x502F</code> — a fold of ruler positions and 64-bit ⇄ float
        round-trips over all eighteen decades) live in this tab. No far pointers — the same source passes
        every way: host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'cosmzoom';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
