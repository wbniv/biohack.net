---
// /snes/domcol — playable in-browser Complex Domain-Colouring SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/domcol.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/domcol.sfc', 'preview/domcol.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `f(z) = (z*z - 1) / (z*z + c);      // complex rational map
// at a pole z*z + c == 0, so we divide by zero:
inv = 1.0f / 0.0f;                  // = +Inf
fr  = numerator * inv;              // Inf, or 0*Inf = NaN
if (fr != fr) colour = POLE;        // isnan: only NaN != itself`;

const notes = [
  ['NaN / unordered compares', 'A pole is where the function divides by zero, producing infinity or NaN. Detecting NaN is the test x != x — true only for NaN — which the compiler lowers to an "unordered" floating-point comparison. Every earlier float demo used only ordered less-than; this is a different set of comparison routines.'],
  ['fold the outcome, not the bits', 'A NaN\'s exact bit pattern is not fully pinned down by the standard, so the self-check never hashes raw float bits — it hashes the colour chosen (pole or not), which is a yes/no answer identical on the host and the console. That keeps the test about the comparison, not the payload.'],
  ['soft float, one op per line', 'The 65816 has no floating-point unit, so every add, multiply and reciprocal is a library call — and each is written on its own line so the compiler can\'t fuse a multiply-add, keeping the result bit-identical to the host.'],
  ['slow on purpose', 'Software floating point is heavy here (~150k cycles per cell), so the picture is a coarse 8x8 grid painted one row at a time, live on the console — proving the soft-float actually runs on hardware — then the palette cycles for a shimmer.'],
];
---

<Base title="Complex Domain-Colouring — bioHACK•NET" description="The poles of a rational complex function painted on a Super Nintendo, detected with NaN / unordered floating-point comparisons. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Domain Colouring</h1>
      <a href="/snes/#cat-fractals" class="rp-cat-chip">Fractals</a>
      <p class="rp-lede">
        <a href="https://en.wikipedia.org/wiki/Domain_coloring">Domain colouring</a> turns a complex
        function into a picture. This one is a rational map, <code>(z²−1)/(z²+c)</code>, and where its
        denominator hits zero it has <em>poles</em> — the divide there yields infinity or
        <a href="https://en.wikipedia.org/wiki/NaN">NaN</a>, which the code catches with the test
        <code>x != x</code> to paint the singularities. Software floating point on a chip with no FPU;
        the picture develops one row at a time, then shimmers. Runs on its own; no joypad needed. Written
        in C and compiled with the <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816
        toolchain (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Domain-Colouring">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the field develops a row at a time, then the palette shimmers.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A pole of a function is a point where it blows up to infinity. Numerically, that's a divide by
        zero — and the result is either infinity or, if the numerator is zero too, "not a number":
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        NaN has a strange property: it is not equal to anything, including itself. So <code>x != x</code>
        is the standard test for it, and it compiles to an <em>unordered</em> comparison — a different
        machine operation than the ordered less-than every other float demo used. The picture stays
        bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0xF3FD</code> — a fold of pole/no-pole colour outcomes,
        including a guaranteed NaN pole) live in this tab. No far pointers — the same source passes every
        way: host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'domcol';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

