---
// /double-pendulum — playable in-browser Double Pendulum chaos SNES demo + notes.
// Boots the shared bsnes-jg WASM player on roms/double-pendulum.sfc. Two pendulums with
// nearly-identical initial angles swing from a shared pivot; their mass-2 traces diverge
// exponentially, showing chaos on a 1990 games console. Compiler stress-test #14.
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/double-pendulum.sfc', 'preview/double-pendulum.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const notes = [
  ['ω² coupling', 'Two int16×int16→int32 multiplies per step (__mulsi3) for the velocity-squared coupling terms that transfer energy between the two pendulum joints'],
  ['D denominator', 'One int32÷int16 signed divide (__divsi3) per step to normalise the shared denominator D = 3 − cos(2Δ) ∈ [2,4]'],
  ['rep/sep', 'Mode-switch brackets under +mos-a16 mark 16-bit accumulator sections — counted in the disasm gate'],
];
---

<Base title="Double Pendulum (Chaos) — bioHACK•NET" description="Two double pendulums with nearly-identical starting angles swing from a shared SNES pivot. Their mass-2 paths trace diverging trails into a bitmap canvas — the visual signature of chaos. Written in C with the llvm-mos 65816 toolchain.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Double Pendulum</h1>
      <a href="/snes/#cat-physics" class="rp-cat-chip">Physics &amp; Simulation</a>
      <p class="rp-lede">
        Two double pendulums hang from a shared pivot with starting angles that differ by a single
        LUT tick — one part in 256 of a full revolution. Their lower-bob paths accumulate as
        white and cyan trails in a bitmap canvas. The trails start together, then diverge
        exponentially: <em>sensitive dependence on initial conditions</em>, the defining property of
        chaos, running on a 1990 games console. Written in C and compiled to a real
        <code>.sfc</code> ROM with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode). Self-running — no joypad needed.
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Double Pendulum chaos demo">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running — trails build up automatically. White = pendulum A, cyan = pendulum B.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch the paths diverge. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A <b>double pendulum</b> is two simple pendulums joined end-to-end. The equations of
        motion for unit masses and unit arm lengths are:
      </p>
      <pre class="rp-code">Δ  = θ₁ − θ₂,   D = 3 − cos(2Δ)
N₁ = −3g·sin θ₁ − g·sin(θ₁−2θ₂) − 2·sin Δ·(ω₂²+ω₁²·cos Δ)
N₂ = 2·sin Δ·(2·ω₁² + 2g·cos θ₁ + ω₂²·cos Δ)
α₁ = N₁/D,   α₂ = N₂/D</pre>
      <p>
        All angles are stored as <code>uint8_t</code> LUT indices (0–255 = 0–2π) and angular
        velocities as <code>int16_t</code> fixed-point. A 256-entry Q8.8 sine LUT
        (<code>DPEND_SIN[a] = round(256·sin(2πa/256))</code>) handles all trigonometry at
        integer speed. Four substeps per V-blank frame give smooth motion without overrunning
        the frame budget.
      </p>

      <h2>Sensitive dependence on initial conditions</h2>
      <p>
        Pendulum A starts with θ₂ = 50/256·2π ≈ 70°; pendulum B with θ₂ = 51/256·2π ≈ 71.4°.
        Both begin at rest. For the first few seconds the paths run nearly together.
        Then the coupling nonlinearity amplifies the initial difference exponentially —
        the Lyapunov exponent is positive — and the two trails separate completely.
        A canvas that starts monochrome ends as an equal mix of white and cyan, with no
        discernible pattern: the hallmark of a chaotic attractor.
      </p>

      <h2>Compiler stress-test #14</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>
      <p>
        The physics kernel lives in a shared C header (<code>examples/65816/dpend.h</code>).
        A host oracle compiles the same code on x86 and prints the golden 16-bit gate hash.
        The gate script then builds the ROM with <code>+mos-a16</code>, runs it under both MAME
        and bsnes-jg to 500 frames, and asserts <code>corpus_result</code> matches the host —
        five-way differential, no far pointers.
      </p>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against two
        emulators (MAME + bsnes-jg). Hit <b>Verify fidelity</b> to reproduce the build gate's
        WRAM assert (chaos gate CRC <code>0xE859</code>) live in this tab. No far pointers,
        so the same binary is checked five ways: host == default == <code>+mos-a16</code> ==
        <code>+mos-xy16</code> == bsnes-jg.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'double-pendulum';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-cat-chip {
    display: inline-block; margin-top: .5rem; padding: 3px 10px;
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-dim); background: var(--bg-soft, #1e2128);
    border: 1px solid var(--rule, #2e3138); border-radius: 4px;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .rp-cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }

  /* player — CENTRED, capped near 2x native */
  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0;
               border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.running { color: var(--accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); font-style: italic; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner :global(b) { color: var(--ink); }
  .rp-banner :global(code) { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }

  /* instructions */
  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc b { color: var(--ink); }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
             background: var(--bg-soft, #1e2128); color: var(--accent); padding: .75rem 1rem;
             border-radius: 6px; margin: .75rem 0; white-space: pre; overflow-x: auto; line-height: 1.6; }
  .rp-table { width: 100%; max-width: 26rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 38rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .68rem; letter-spacing: .08em;
                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .85em; }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
