---
// /snes/editdist — playable in-browser Edit-Distance DP SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/editdist.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/editdist.sfc', 'preview/editdist.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `D[i][j] = min(                        // fill the table cell by cell
  D[i-1][j-1] + (A[i] != B[j]),       //  substitute (or match)
  D[i-1][j]   + 1,                    //  delete
  D[i][j-1]   + 1);                   //  insert
// then walk back from D[m][n] to D[0][0] for the alignment`;

const notes = [
  ['2-D dynamic programming', 'A grid of sub-answers is filled in, each cell built from three neighbours it already knows. The edit distance between two whole words falls out of the bottom-right corner. A doubly-indexed table (D[i][j]) with a min recurrence — a loop nest no earlier demo runs.'],
  ['min recurrence', 'Each cell takes the cheapest of three moves — substitute, delete, insert. That min-of-three, over the whole grid, is the entire algorithm.'],
  ['backtracking', 'Once the table is full, tracing backward from the corner — always to whichever neighbour produced the minimum — recovers the actual sequence of edits: the highlighted path.'],
  ['cross-checked', 'The build gate verifies the distance is symmetric — editing A into B costs the same as B into A — so any slip in the indexing or the recurrence is caught.'],
];
---

<Base title="Edit-Distance DP — bioHACK•NET" description="The Levenshtein edit-distance table filled in and backtracked on a Super Nintendo — a 2-D dynamic-programming grid with a min recurrence and an optimal-path trace. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Edit Distance</h1>
      <p class="rp-lede">
        How many single-character edits turn one word into another? The
        <a href="https://en.wikipedia.org/wiki/Levenshtein_distance">edit distance</a> is answered by
        <a href="https://en.wikipedia.org/wiki/Dynamic_programming">dynamic programming</a>: fill a grid
        where each cell is the cheapest of three moves from its neighbours, and the answer appears in the
        corner. Then trace backward to recover the actual alignment — the bright path through the
        cost heat-map. Runs on its own; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Edit-Distance DP">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the table and its alignment path cycle through word pairs.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        Dynamic programming solves a big problem by filling a table of smaller ones. For edit distance,
        cell <code>[i][j]</code> is the distance between the first i letters of one word and the first j of
        the other:
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        Fill the whole grid and the answer is the bottom-right corner; walk back from it and you recover
        exactly which letters were kept, changed, added or dropped — the lit path. It stays bit-exact
        across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0xFB59</code> — the edit distances of many random string pairs,
        each checked for symmetry) live in this tab. No far pointers — the same source passes every way:
        host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'editdist';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }
  .rp-lede em { font-style: italic; }

  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0;
               border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.running { color: var(--accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); font-style: italic; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner :global(b) { color: var(--ink); }
  .rp-banner :global(code) { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }

  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc em { font-style: italic; }
  .rp-doc b { color: var(--ink); }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
             background: var(--bg-soft, #1e2128); color: var(--accent); padding: .75rem 1rem;
             border-radius: 6px; margin: .75rem 0; white-space: pre; overflow-x: auto; line-height: 1.6; }
  .rp-table { width: 100%; max-width: 26rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 44rem; }
