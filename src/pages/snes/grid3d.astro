---
// /snes/grid3d — playable in-browser 3-D Grid Voxel Life SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/grid3d.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/grid3d.sfc', 'preview/grid3d.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `uint8_t grid[6][6][6];        // a true 3-D array
next = grid[z][y][x];         // compiler emits z*36 + y*6 + x
count = sum of the 26 Moore neighbours (wrapped);
alive ? survive(4..7) : born(5..6);`;

const notes = [
  ['true 3-D array', 'This is not a flat buffer with hand-written y*W + x offsets — it is a genuine grid[6][6][6], so every grid[z][y][x] makes the compiler generate the plane and row stride arithmetic z*36 + y*6 + x. With a non-power-of-2 side, those strides are real math, not shifts.'],
  ['26 reads per cell', 'The automaton counts all 26 Moore neighbours of every cell each step, so the multi-dimensional index is exercised tens of thousands of times per generation — a heavy workout for the compiler\'s N-dimensional address lowering.'],
  ['3-D cellular automaton', 'A life-like rule (survive with 4..7 neighbours, born with 5..6) run in three dimensions instead of two. It settles into a shifting, breathing voxel structure rather than dying or filling.'],
  ['integer, bit-exact', 'Cells are bytes and the indexing is integer, so the automaton evolves identically on the host and the 65816 — the build gate folds every cell of every generation and asserts a match to the bit.'],
];
---

<Base title="3-D Grid Voxel Life — bioHACK•NET" description="A 3-D cellular automaton in a true uint8 grid[6][6][6] array on a Super Nintendo, tumbling as a depth-shaded voxel cube — the compiler generates the z*36 + y*6 + x stride arithmetic for every grid[z][y][x]. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">3-D Grid Voxel Life</h1>
      <a href="/snes/#cat-cellular" class="rp-cat-chip">Cellular Automata</a>
      <p class="rp-lede">
        <a href="https://en.wikipedia.org/wiki/Conway%27s_Game_of_Life">Life</a> in three dimensions: a
        life-like <a href="https://en.wikipedia.org/wiki/Cellular_automaton">cellular automaton</a> living
        in a true <code>uint8 grid[6][6][6]</code> array, tumbling as a depth-shaded voxel cube. Every
        <code>grid[z][y][x]</code> makes the compiler generate the plane-and-row stride math — the thing
        this demo is really testing — while the automaton breathes and shifts on a Super Nintendo. All
        integer, so it's bit-exact. Runs on its own; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running 3-D Grid Voxel Life">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — a 3-D automaton tumbles as a voxel cube.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        Each generation, every cell counts its 26 neighbours in the 3-D grid and lives or dies by the
        rule; the surviving cells are projected and drawn as a rotating cube:
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        The point is the <code>grid[z][y][x]</code> access itself — a true multi-dimensional array where
        the compiler must emit the stride arithmetic, done tens of thousands of times per step and
        identical across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0xFCDE</code> — a fold of every cell of three automaton
        generations) live in this tab. No far pointers — the same source passes every way: host ==
        default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg, <code>-verify</code>
        clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'grid3d';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

