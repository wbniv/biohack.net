---
// /snes/iir-scope — playable in-browser IIR Resonant-Filter Scope SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/iir-scope.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/iir-scope.sfc', 'preview/iir-scope.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const iircode = `// per sample, per resonator — a1 has a small runtime vibrato:
int32_t y = (a1 * y1[k] + a2 * y2[k]) >> 12;   // ← the feedback (32-bit multiply)
if (k == pluck) y += IMPULSE;                  // "pluck" = impulse excitation
y2[k] = y1[k];  y1[k] = y;                      // shift the two-sample state
// y[n] depends on y[n-1] AND y[n-2] — the loop can't be reordered.`;

const notes = [
  ['y[n] ← y[n-1], y[n-2]', 'Each output sample is fed back from the two previous outputs. Unlike a feed-forward FFT (whose stages can be reordered/parallelized), this dependency chain is strictly serial — every sample waits on the last.'],
  ['2-pole resonator', 'y[n] = 2·r·cos(ω)·y[n-1] − r²·y[n-2] + x[n]. An impulse (the "pluck") makes it ring: a decaying sinusoid at frequency ω, decaying at rate r. Four of them tuned to a chord.'],
  ['__mulsi3', 'The a1·y[n-1] feedback term is a genuine 32-bit multiply. A small runtime vibrato on the coefficient keeps it from being folded to shift-adds (and makes the chord chorus-wobble).'],
  ['non-reorderable', 'The whole point: the compiler must respect the serial data dependency. A miscompile that reordered the state updates would diverge the differential CRC — which it does not.'],
];
---

<Base title="IIR Resonant-Filter Scope — bioHACK•NET" description="Four 2-pole IIR resonators plucked into a live oscilloscope on a Super Nintendo — a recursive feedback dependency chain (y[n] from y[n-1], y[n-2]) that can't be reordered like a feed-forward FFT. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">IIR Resonant-Filter Scope</h1>
      <a href="/snes/#cat-signals" class="rp-cat-chip">Signals & Audio</a>
      <p class="rp-lede">
        Four 2-pole <a href="https://en.wikipedia.org/wiki/Infinite_impulse_response">IIR</a>
        resonators, plucked in turn by impulses, ringing out on a live oscilloscope — running on a
        Super Nintendo. Each output sample is <em>fed back</em> from the two previous outputs
        (<code>y[n] = a₁·y[n-1] + a₂·y[n-2] + x[n]</code>), a strictly serial dependency chain the
        compiler <em>cannot</em> reorder or vectorize the way it can a feed-forward FFT. Runs
        automatically; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the IIR scope">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the resonators are plucked and ring on their own.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A resonator is a filter with feedback: hit it once (an impulse — a "pluck") and it rings,
        producing a decaying sinusoid, like a struck string or bell. This demo runs four of them
        tuned to a chord, arpeggiated, and draws the summed output as a scrolling oscilloscope
        trace. The core is three lines:
      </p>
      <pre class="rp-code">{iircode}</pre>
      <p>
        Because <code>y[n]</code> depends on <code>y[n-1]</code> and <code>y[n-2]</code>, the loop is
        a serial chain — the exact opposite of the parallelizable butterflies in a Fourier transform.
        It's the kind of code where a compiler that reorders too aggressively would silently corrupt
        the result; here it stays bit-exact.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0x49BD</code> — a rotate-XOR fold of 400 output samples)
        live in this tab. No far pointers — the same source passes every way: host == default ==
        <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'iir-scope';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
