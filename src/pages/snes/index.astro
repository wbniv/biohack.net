const byCategory = categories.map(cat => ({
  ...cat,
  items: demos.filter(d => d.category === cat.id),
})).filter(c => c.items.length > 0);
---

<Base title="SNES Demos — bioHACK•NET" description={`${demos.length} in-browser Super Nintendo demos compiled from C with the llvm-mos-65816 toolchain — each a stress-test for the compiler's 16-bit-accumulator codegen (+mos-a16). Play them in your browser.`}>
  <main class="gl-wrap">

    <header class="gl-hero">
      <a class="gl-back" href="/">← biohack.net</a>
      <h1 class="gl-title">SNES Demos</h1>
      <p class="gl-lede">
        {demos.length} Super Nintendo programs compiled from C with an
        <a href="https://indri.studio/apps/llvm-mos-65816/">LLVM-based 65816 toolchain</a>
        — each a stress-test for the compiler's 16-bit-accumulator codegen and a playable
        ROM verified against MAME and bsnes-jg. Click any card to play.
      </p>
    </header>

    {byCategory.map(({ id, label, items }) => (
      <section class="cat-shelf" id={`cat-${id}`}>
        <div class="cat-header">
          <h2 class="cat-title">{label}</h2>
          <div class="cat-nav">
            <button class="cat-btn cat-prev" aria-label={`Scroll ${label} left`}>‹</button>
            <button class="cat-btn cat-next" aria-label={`Scroll ${label} right`}>›</button>
          </div>
        </div>
        <ul class="cat-row" role="list">
          {items.map(({ slug, title, keys }) => {
            const v = previewV(slug);
            return (
              <li class="cat-card">
                <a href={`/snes/${slug}/`} class="cat-card-link" aria-label={`Play ${title}`}>
                  <div class="cat-thumb-wrap">
                    <img
                      class="cat-thumb"
                      src={`/play/preview/${slug}.png${v ? `?v=${v}` : ''}`}
                      alt={`${title} preview`}
                      width="256"
                      height="224"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="cat-play-overlay" aria-hidden="true">▶</div>
                  </div>
                  <div class="cat-card-body">
                    <h3 class="cat-card-title">{title}</h3>
                    <p class="cat-card-keys">{keys}</p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}

    <p class="gl-foot">
      Each ROM boots in the bsnes-jg WASM core — no install, no plugin. Hit
      <b>Verify fidelity</b> on any demo page to replay the CI gate live in the browser.
    </p>

  </main>
</Base>

<script is:inline>
  document.querySelectorAll('.cat-shelf').forEach(function(shelf) {
    var row = shelf.querySelector('.cat-row');
    function scrollAmt() { return Math.floor(row.clientWidth * 0.85); }
    var prev = shelf.querySelector('.cat-prev');
    var next = shelf.querySelector('.cat-next');
    if (prev) prev.addEventListener('click', function() { row.scrollBy({ left: -scrollAmt(), behavior: 'smooth' }); });
    if (next) next.addEventListener('click', function() { row.scrollBy({ left:  scrollAmt(), behavior: 'smooth' }); });
  });
</script>

<style>
  .gl-wrap {
    max-width: 960px;
    margin-inline: auto;
    padding: 2.5rem 1.25rem 5rem;
  }

  /* ── back link ──────────────────────────────────────── */
  .gl-back {
    display: inline-block;
    font-size: 12px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    letter-spacing: 0.06em;
    color: var(--ink-dim);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }
  .gl-back:hover { color: var(--accent); }

  /* ── hero ───────────────────────────────────────────── */
  .gl-hero { max-width: 42rem; margin-bottom: 2.75rem; }
  .gl-title {
    font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(2rem, 9vw, 3.2rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .gl-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink);
    opacity: 0.85;
    margin: 0;
  }
  .gl-lede a { color: var(--accent); text-decoration: none; }
  .gl-lede a:hover { text-decoration: underline; }

  /* ── category shelf ─────────────────────────────────── */
  .cat-shelf { margin-bottom: 2.75rem; }

  .cat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .cat-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin: 0;
  }
  .cat-nav { display: flex; gap: 0.35rem; }
  .cat-btn {
    background: transparent;
    color: var(--ink-dim);
    cursor: pointer;
    font-size: 15px;
    line-height: 1;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    border: 1px solid var(--accent-soft, rgba(194,65,12,0.35));
    border-radius: 6px;
    padding: 0.2rem 0.55rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .cat-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* ── scrollable row ─────────────────────────────────── */
  .cat-row {
    display: flex;
    gap: 10px;
    list-style: none;
    padding: 0 0 6px;
    margin: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .cat-row::-webkit-scrollbar { display: none; }

  /* ── card ───────────────────────────────────────────── */
  .cat-card {
    flex: 0 0 180px;
    scroll-snap-align: start;
    border: 1px solid var(--rule);
    background: var(--bg-soft);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .cat-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(194, 65, 12, 0.3), 0 0 40px rgba(194, 65, 12, 0.1);
  }
  .cat-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ── thumbnail ──────────────────────────────────────── */
  .cat-thumb-wrap {
    position: relative;
    background: #000;
    line-height: 0;
    overflow: hidden;
  }
  .cat-thumb {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 256 / 224;
    image-rendering: pixelated;
    object-fit: cover;
    transition: opacity 0.2s;
  }
  .cat-card:hover .cat-thumb { opacity: 0.82; }
  .cat-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
