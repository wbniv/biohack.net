---
// /snes/lzdec — playable in-browser LZ77 Image-Decompress Reveal SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/lzdec.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/lzdec.sfc', 'preview/lzdec.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const lzcode = `for each token:
    literal?  ->  out[dp++] = input byte
    match?    ->  from = dp - offset
                  copy length bytes: out[dp++] = out[from++]
                                     // reads its OWN just-written output`;

const notes = [
  ['sliding window', 'LZ77 compresses by replacing repeated data with a back-reference: "copy N bytes from M bytes ago". The decoder is a tiny state machine reading a flag-driven token stream of literals and (offset, length) matches.'],
  ['back-reference', 'A match copies from the output buffer the decoder is still filling. The copy is byte-by-byte and output-relative — pointer arithmetic reading bytes the loop just wrote. It is the self-referential core no other demo in the battery runs.'],
  ['overlap = RLE', 'When the offset is smaller than the length, the copy overlaps its own tail — so a single short match expands into a long repeating run. That is how LZ subsumes run-length encoding for free.'],
  ['bit-exact', 'Pure byte pointer arithmetic — no multiply, no divide, no libcall. The gate folds the whole 256-byte decoded image; host == default == +mos-a16 == +mos-xy16 == bsnes-jg, byte for byte.'],
];
---

<Base title="LZ77 Image-Decompress Reveal — bioHACK•NET" description="A compressed picture decoded on a Super Nintendo by an LZ77 byte-stream decoder that copies back-references from its own output (sliding window), revealed progressively. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">LZ77 Reveal</h1>
      <p class="rp-lede">
        A compressed picture loading in on a Super Nintendo, decoded by an
        <a href="https://en.wikipedia.org/wiki/LZ77_and_LZ78">LZ77</a> byte-stream decoder — the same
        family behind zip and PNG. Its trick: matches copy back-references from the
        <em>decoder's own output buffer</em>, so an overlapping copy expands a repeating run for free.
        Runs automatically; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the LZ77 reveal">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the compressed image decodes and reveals itself.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        LZ77 shrinks data by pointing backward: instead of repeating bytes, it stores "copy N bytes from
        M ago". Decoding is a small loop reading a token stream of literals and matches:
      </p>
      <pre class="rp-code">{lzcode}</pre>
      <p>
        The clever part is that a match reads from the buffer being written — so when the copy distance
        is short, it overlaps its own output and a two-byte token expands into a long run. Here it
        reconstructs a diamond image; the source is 256 cells, the compressed stream just 56 bytes. It
        stays bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate hash <code>0x0100</code> — a fold of the full 256-byte decoded image)
        live in this tab. No far pointers — the same source passes every way: host == default ==
        <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg, <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'lzdec';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
