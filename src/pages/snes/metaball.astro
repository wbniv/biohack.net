---
// /snes/metaball — playable in-browser Union Type-Pun Metaballs SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/metaball.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/metaball.sfc', 'preview/metaball.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const rsqrtcode = `float y = number;
i  = *(uint32_t*)&y;             // read the float's bits AS an int
i  = 0x5f3759df - (i >> 1);      // what the...?
y  = *(float*)&i;                // read the int's bits BACK AS a float
y  = y * (1.5 - x2*y*y);         // one Newton step -> 1/sqrt(x)`;

const notes = [
  ['type-punning', 'The trick reads a float\'s storage as an integer, mangles the bits, and reads them back as a float. That aliased load/store — the same four bytes interpreted two ways through a union — is the codegen path under test.'],
  ['0x5f3759df', 'The legendary magic constant from Quake III\'s source. Halving the integer bits approximates halving the exponent (a square root in log space); subtracting from the constant negates it (the reciprocal). On the 65816 it appears as the byte immediates #$5f #$37 #$59 #$df.'],
  ['soft-float', 'The 65816 has no floating-point unit, so every multiply is a runtime call (__mulsf3). The single Newton-Raphson refinement is written one operation per statement so the target never fuses a multiply-add differently from the host — keeping it bit-exact.'],
  ['metaballs', 'The reciprocal-sqrt gives 1/dist falloff around each blob; summing four of them and thresholding the total yields gooey shapes that merge and split. The gate folds the raw float bits of the bit hack; host == default == +mos-a16 == +mos-xy16 == bsnes-jg, byte for byte.'],
];
---

<Base title="Union Type-Pun Metaballs — bioHACK•NET" description="Merging metaballs on a Super Nintendo whose 1/dist falloff is the Quake III fast inverse square root — a union float/uint32 bit hack with magic constant 0x5f3759df. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Metaballs</h1>
      <a href="/snes/#cat-rendering" class="rp-cat-chip">Rendering & Graphics</a>
      <p class="rp-lede">
        Gooey blobs merging and splitting on a Super Nintendo, their glow computed by the legendary
        <a href="https://en.wikipedia.org/wiki/Fast_inverse_square_root">Quake III fast inverse square
        root</a> — the <code>union &#123; float f; uint32_t i; &#125;</code> bit hack that reads a float's storage
        <em>as an integer</em>, mangles it with the magic constant <code>0x5f3759df</code>, and reads it
        back <em>as a float</em>. Runs automatically; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the metaballs">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the blobs merge and split on their own.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        Metaballs glow with a <code>1/distance</code> falloff, so drawing them needs a reciprocal square
        root — normally a slow operation. Quake III famously computed it with a bit-level trick that treats
        the float's raw bytes as an integer:
      </p>
      <pre class="rp-code">{rsqrtcode}</pre>
      <p>
        Halving the integer form of the bits roughly halves the exponent (a square root), and subtracting
        from the magic constant negates it (the reciprocal); one Newton step cleans up the estimate. Here
        it drives four blobs summed into a field. It stays bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate hash <code>0xAEBE</code> — a fold of the raw float bits of the bit hack
        over a sweep of inputs) live in this tab. No far pointers — the same source passes every way:
        host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'metaball';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-cat-chip {
    display: inline-block; margin-top: .5rem; padding: 3px 10px;
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-dim); background: var(--bg-soft, #1e2128);
    border: 1px solid var(--rule, #2e3138); border-radius: 4px;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .rp-cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }
  .rp-lede em { font-style: italic; }

  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0;
               border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
