---
// /snes/msquares — playable in-browser Marching-Squares SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/msquares.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/msquares.sfc', 'preview/msquares.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `case = (tl>=iso)<<3 | (tr>=iso)<<2       // 4 corner signs
     | (br>=iso)<<1 | (bl>=iso);        // -> a 4-bit index
edges = MS_SEG[case];                   // which edges cross (16-case LUT)
t = (iso - va) / (vb - va);             // crossing point on each edge`;

const notes = [
  ['the 4-bit case', 'Each grid cell has four corners; each is either inside the shape or outside. Those four yes/no bits make a number 0..15 — the case. A 16-entry table then says, for that case, which of the cell\'s edges the contour line crosses.'],
  ['edge interpolation', 'A crossing is not snapped to the edge midpoint — it is placed by linear interpolation, t = (iso - a) / (b - a), so the contour is smooth. That divide, per crossing, is the heart of the inner loop.'],
  ['contour extraction', 'The scalar field here is a sum of moving blobs; marching squares pulls out the single iso-line where the field equals a threshold. It is how contour maps, medical isosurfaces and metaball outlines are drawn.'],
  ['integer, bit-exact', 'Coordinates are 16-bit and the field and interpolation are 32-bit integers, so the extracted contour is identical on the host and the 65816 — the build gate folds the case indices and crossing points and asserts a match.'],
];
---

<Base title="Marching Squares — bioHACK•NET" description="Iso-contours of a moving metaball field extracted on a Super Nintendo by marching squares — a 16-case edge lookup table indexed by the four corner signs, plus edge-crossing interpolation. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Marching Squares</h1>
      <a href="/snes/#cat-cellular" class="rp-cat-chip">Cellular Automata</a>
      <p class="rp-lede">
        How do you draw the outline of a blob that has no outline — just a field of values? You
        <em>march</em>: <a href="https://en.wikipedia.org/wiki/Marching_squares">marching squares</a> walks
        a grid over the field, and in each cell reads the four corners as a 4-bit case, looks up which
        edges the contour crosses, and interpolates where. The result is a clean iso-line traced around
        merging, splitting metaballs — here on a Super Nintendo, all integer, so it's bit-exact. Runs on
        its own; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Marching Squares">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — blobs merge and split under a traced contour.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        For each cell of the grid, the four corners are thresholded against the iso value into a 4-bit
        case, a 16-entry table gives the edges the contour crosses, and each crossing is interpolated:
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        Stitch those little segments together across the whole grid and you get the smooth iso-contour of
        the field — the yellow outline around the blobs. It's a case-table lookup plus a divide per
        crossing, identical across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0x86A7</code> — a fold of the marching-squares case indices and
        crossing points over two frames) live in this tab. No far pointers — the same source passes every
        way: host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'msquares';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

