                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .85em; }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
