---
// /snes/perlin — playable in-browser Perlin Noise SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/perlin.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/perlin.sfc', 'preview/perlin.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `fade(t) = 6t^5 - 15t^4 + 10t^3;      // smooth S-curve blend
n = lerp(                             // blend the 4 corner gradients
      lerp(dot(gAA), dot(gBA), fade(xf)),
      lerp(dot(gAB), dot(gBB), fade(xf)),
      fade(yf));`;

const notes = [
  ['gradient noise', 'Unlike random dots, Perlin noise is smooth: it places a random gradient at each grid corner and blends between them, so nearby points get similar values. The result looks like clouds, smoke or marble — coherent, not fuzzy.'],
  ['the fade polynomial', 'The blend uses a specific quintic curve, 6t^5-15t^4+10t^3, which is flat at both ends (its first and second derivatives vanish) so the noise has no visible grid seams. Evaluating that polynomial per sample is the heart of it.'],
  ['gradient dots + lerp', 'At each corner the gradient is dotted with the offset to the sample point, and the four results are interpolated with the fade curve. Lots of multiply-adds — done here entirely in fixed point.'],
  ['no floats, bit-exact', 'It is computed in 8.8 fixed point with a seeded integer shuffle for the permutation, so there is no rounding ambiguity — the field is identical on the host and the 65816, a sharp differential.'],
];
---

<Base title="Perlin Noise — bioHACK•NET" description="A flowing smoke/marble field on a Super Nintendo, coloured by fixed-point Perlin gradient noise — a permutation table, the 6t^5-15t^4+10t^3 fade polynomial, gradient dot products and lerp. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Perlin Noise</h1>
      <a href="/snes/#cat-rendering" class="rp-cat-chip">Rendering & Graphics</a>
      <p class="rp-lede">
        <a href="https://en.wikipedia.org/wiki/Perlin_noise">Perlin noise</a> is the smooth, organic
        randomness behind decades of procedural clouds, terrain and textures. It places a random gradient
        at each grid corner and blends between them with a carefully-shaped curve, so the field looks like
        drifting smoke rather than static. Here it flows across a Super Nintendo — computed entirely in
        fixed point, so it's bit-exact. Runs on its own; no joypad needed. Written in C and compiled with
        the <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Perlin Noise">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — the noise field drifts like smoke.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        The trick is the blend. Each cell of the grid gets a random direction; a sample point in between is
        the fade-weighted mix of the four surrounding gradients:
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        That fade curve, <code>6t⁵−15t⁴+10t³</code>, is what removes the blocky grid and leaves a smooth,
        flowing field. It's all multiply-adds in fixed point here, and the result is identical across every
        codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate CRC <code>0xA72D</code> — a fold of noise samples and fade-polynomial
        values) live in this tab. No far pointers — the same source passes every way: host == default ==
        <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg, <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'perlin';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
