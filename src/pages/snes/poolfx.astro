---
// /snes/poolfx — playable in-browser Free-List Pool Allocator SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/poolfx.sfc. Built from the
// snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/poolfx.sfc', 'preview/poolfx.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const allocode = `alloc():  i = head;  head = slot[head].next;   // pop the free head
free(i):  slot[i].next = head;  head = i;      // push it back (LIFO)

// spawn a particle → alloc();   particle dies → free(i)`;

const notes = [
  ['free list', 'A singly-linked stack of unused slots threaded through the slots themselves — each free slot stores the index of the next free slot in its own next field. No separate bookkeeping array, no malloc: recycling 48 fixed slots is two pointer writes.'],
  ['pop / push', 'Spawning a particle pops the head off the free list (alloc); a particle dying pushes its slot back (free). Distinct from a bump/arena pool that only ever grows then resets — here individual slots come and go every frame.'],
  ['indexed slot chase', 'On the 65816 the link walk head = slot[head].next becomes an indexed struct-array load (ldy-indexed). The differential proves that recycling — across default-8-bit, +mos-a16 and +mos-xy16 — is bit-exact, with zero arithmetic libcalls (pure pointer/index math).'],
  ['fountain', 'The pool drives a particle fountain: three births per frame from the nozzle, gravity pulling each spark down, death (life expiry or off-screen) recycling the slot. When births outrun the 48 slots the pool saturates and drops births — the exhaustion path is exercised too.'],
];
---

<Base title="Free-List Pool Allocator — bioHACK•NET" description="A particle fountain on a Super Nintendo whose 48 slots are recycled through a manual singly-linked LIFO free list threaded through the slots — alloc pops the head, free pushes it back. Written in C with the llvm-mos 65816 toolchain under +mos-a16.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Pool Fountain</h1>
      <a href="/snes/#cat-classics" class="rp-cat-chip">Games & Classics</a>
      <p class="rp-lede">
        A sparking fountain on a Super Nintendo, drawn by a hand-rolled
        <a href="https://en.wikipedia.org/wiki/Free_list">free-list pool allocator</a> — no
        <code>malloc</code>. Forty-eight fixed particle slots are recycled through a singly-linked
        <em>LIFO free list threaded through the slots themselves</em>: a birth <em>pops</em> the free
        head, a death <em>pushes</em> the slot back. Continuous alloc/free churn every frame. Runs
        automatically; no joypad needed. Written in C and compiled with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain
        (<code>+mos-a16</code>, 16-bit accumulator mode).
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the free-list pool fountain">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running demo — sparks are born and die as the pool recycles slots.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A pool allocator hands out slots from a fixed array. To know which slots are free without
        scanning, it keeps a <em>free list</em>: a linked stack whose links live <em>inside the free
        slots</em>. Each free slot stores, in its own <code>next</code> field, the index of the next
        free one; a single <code>head</code> points at the top of the stack.
      </p>
      <pre class="rp-code">{allocode}</pre>
      <p>
        Allocation pops the head; freeing pushes the slot back on top — two pointer writes, no search,
        no heap. Here the pool feeds a fountain: three sparks are born per frame, gravity brings each
        down, and death recycles the slot for the next birth. The whole birth/death cycle stays
        bit-exact across every codegen mode.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg
        (and MAME where the SPC700 IPL is present). Hit <b>Verify fidelity</b> to reproduce the build
        gate's WRAM assert (gate hash <code>0x2B9B</code> — a fold of the full pool state over 100
        simulated frames) live in this tab. No far pointers — the same source passes every way:
        host == default == <code>+mos-a16</code> == <code>+mos-xy16</code> == bsnes-jg,
        <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'poolfx';
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

