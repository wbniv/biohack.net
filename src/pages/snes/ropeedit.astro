---
// /ropeedit — Gap-Buffer Rope Editor. Compiler stress-test #96 (Round 6, harden-the-fixes).
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/ropeedit.sfc', 'preview/ropeedit.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `// a gap buffer: text lives on either side of a movable "gap"
//   text = buf[0, gap_start)  ++  buf[gap_end, N)
uint8_t buf[576]; uint16_t gap_start, gap_end;

insert(ch): buf[gap_start++] = ch;      // typing fills the gap
delete():   gap_start--;                // backspace grows the gap

move(pos):  // move the cursor — memmove text across the gap, EITHER way
  if (pos < gap_start) {                 // cursor left  -> shift text right
    n = gap_start - pos;
    memmove(&buf[gap_end - n], &buf[pos], n);   // n can exceed 256 bytes
  } else {                               // cursor right -> shift text left
    n = pos - gap_start;
    memmove(&buf[gap_start], &buf[gap_end], n);
  }`;

const notes = [
  ['the gap buffer', 'A gap buffer is how many real text editors store a line: the characters sit on either side of an empty “gap” at the cursor. Typing writes into the gap; backspace enlarges it. The only expensive operation is moving the cursor a long way — that memmoves all the text between the old and new cursor across the gap.'],
  ['memmove, both directions, at scale', 'Moving the cursor left shifts text toward the high end; moving it right shifts text toward the low end — so both memmove copy directions fire. With a 576-byte buffer holding ~480 characters, a cursor jump moves more than 256 bytes, which forces the copy onto the 65816’s 16-bit-index path.'],
  ['the 256-byte boundary', 'The 65816 addresses memory with 8-bit or 16-bit index registers. A copy of ≤256 bytes fits an 8-bit index; more than that needs a 16-bit index. The buffer is sized past 256 so every cursor-move memmove is driven by a 16-bit index — the exact path a real compiler bug once corrupted.'],
  ['the bug this guards (#23, patch 0002)', 'Under 16-bit-index mode (+mos-xy16), an earlier compiler could slip a “switch index to 8-bit” instruction (sep #$10) between writing a 16-bit index and reading it, zeroing the high byte and mis-addressing the copy. The fix reloads the index after each width switch. This is the fourth and final Cluster-A demo guarding it — after a synthetic memmove, an indirect-pointer reversal, and an indexed store, this one exercises memmove as a real editor primitive, at scale, in both directions.'],
  ['result: bit-exact in every mode', 'A gap buffer is a pure byte shuffle — identical on the host and on the SNES. A scripted edit stream (type / delete / jump) runs, and the gate folds all 576 bytes each step into a CRC: host == default == +mos-a16 == +mos-xy16 on both MAME and bsnes-jg, -verify-machineinstrs clean. A dropped index high byte would smear the text and change the CRC. It does not — the fix holds, now permanently regression-guarded.'],
  ['the visual', 'The 576-byte buffer is drawn as a 16×16 window of colour cells (colour by byte class). As the cursor jumps around and text is typed and deleted, the coloured text blocks slide across the gap — the memmoves made visible.'],
];
---

<Base title="Gap-Buffer Rope Editor — bioHACK•NET" description="A text gap buffer whose cursor moves memmove text across the gap on a Super Nintendo — both directions, past the 256-byte boundary. Compiler stress-test #96: hardens the +mos-xy16 index-width fix at scale, as a real editor primitive.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Gap-Buffer Rope Editor</h1>
      <a href="/snes/#cat-algorithms" class="rp-cat-chip">Algorithms &amp; Data</a>
      <p class="rp-lede">
        A text <em>gap buffer</em> — the data structure inside many real editors — whose cursor moves
        <code>memmove</code> the text across the gap, <em>both</em> directions and more than 256 bytes
        at a time. This is compiler stress-test #96, the final Cluster-A demo: it runs the exact
        scenario a real <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a> bug once corrupted
        — a 16-bit-indexed copy under <code>+mos-xy16</code> — at scale, as a working editor primitive
        rather than a synthetic loop.
      </p>
    </header>

    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Gap-Buffer Rope Editor">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running — text blocks slide across the gap as the cursor jumps and edits.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        In a gap buffer the characters live on either side of a movable empty region at the cursor.
        Typing and deleting only touch the gap’s edge and are cheap. The one costly operation is a
        long cursor jump: all the text between the old and new position must be copied across the gap
        with <code>memmove</code>, which handles the overlapping ranges safely.
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        The buffer holds 576 bytes with ~480 characters typed in, so a cursor jump copies more than
        256 bytes — a 16-bit-indexed move. A scripted edit stream drives jumps in both directions and
        folds all 576 bytes into a rolling CRC each step. The picture is the proof: a wrong index
        would smear the text and change the CRC.
      </p>

      <h2>Compiler stress-test #96 — Round 6: hardening the fixes</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg and MAME.
        Hit <b>Verify fidelity</b> to reproduce the build gate's WRAM assert
        (gate CRC <code>0x2361</code> — a fold of 20 edit steps × 576 bytes) live in this tab.
        No far pointers — <code>host == default == +mos-a16 == +mos-xy16</code>,
        <code>-verify</code> clean.</p>
    </section>
  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'ropeedit';
    window.BJG_BUST = bust;
    window.BJG_SELFCHECK = { off: 0x6a, len: 2, want: 0x2361, frames: 500, label: 'gap-buffer rope editor CRC' };
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-cat-chip {
    display: inline-block; margin-top: .5rem; padding: 3px 10px;
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-dim); background: var(--bg-soft, #1e2128);
    border: 1px solid var(--rule, #2e3138); border-radius: 4px;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .rp-cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }
  .rp-lede em { font-style: italic; }
  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0; border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.running { color: var(--accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); font-style: italic; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner :global(b) { color: var(--ink); }
  .rp-banner :global(code) { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc b { color: var(--ink); }
  .rp-doc em { font-style: italic; }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
             background: var(--bg-soft, #1e2128); color: var(--accent); padding: .75rem 1rem;
             border-radius: 6px; margin: .75rem 0; white-space: pre; overflow-x: auto; line-height: 1.6; }
  .rp-table { width: 100%; max-width: 26rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 44rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .68rem; letter-spacing: .08em;
                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .85em; }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
