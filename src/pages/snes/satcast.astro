---
// /snes/satcast — playable in-browser Saturating-Cast Kaleidoscope SNES demo + notes.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/satcast.sfc.
// Compiler stress-test #77: fminf → G_FMINNUM + fmaxf → G_FMAXNUM + (int16_t) → G_FPTOSI.
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/satcast.sfc', 'preview/satcast.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `// Per-tile colour in the 6-fold hex kaleidoscope:
// q=tx-8, r=ty-8, s=-q-r  (hex axial coords)
// a,b,c = sort(|q|,|r|,|s|)   (first sextant → 6-fold symmetry)

float fa = (float)a;
float a2 = fa * fa;         // __mulsf3: 0..225
float tb = (float)b * (float)b * 50.0f;  // __mulsf3 x2
float raw = a2 * 200.0f - tb;  // __mulsf3 + __subsf3

float intensity = raw + phase_f;  // __addsf3

// Saturating cast:
float lo = fminf(32767.0f, intensity);  // G_FMINNUM
float hi = fmaxf(-32768.0f, lo);        // G_FMAXNUM
int16_t iv = (int16_t)hi;              // G_FPTOSI (legalizer inserts NaN guard)

// colour = top 2 bits of (iv shifted to unsigned):
colour = (uint8_t)((uint16_t)(iv + 32768) >> 14);
// → INT16_MIN→0, [-16384,-1]→1, [0,16383]→2, [16384,INT16_MAX]→3`;

const notes = [
  ['G_FMINNUM', 'fminf(32767.0f, x) lowers to G_FMINNUM → SDK fminf (math.cc:18 in llvm-mos-sdk). On the 65816 this is a function call to the soft-float min comparison, not an inline instruction. This is the first demo in the battery to call fminf/fmaxf.'],
  ['G_FMAXNUM', 'fmaxf(-32768.0f, lo) lowers to G_FMAXNUM → SDK fmaxf (math.cc:19). Together with G_FMINNUM, this creates the two-sided clamp that prevents the int16 cast from hitting undefined behaviour on out-of-range floats.'],
  ['G_FPTOSI + legalizer :502', '(int16_t)hi lowers to G_FPTOSI. The MOS legalizer at line 502 inserts a NaN guard (buildIsFPClass(fcNan) + G_SELECT) so that a NaN input maps to INT16_MIN instead of UB. This is distinct from demo #44 (integer __builtin_add_overflow / G_UADDO) and #59 (exact 64-bit round-trip, no clamp).'],
  ['saturation plateaus', 'Tiles with large a (Chebyshev hex distance from centre) compute a² × 200 which exceeds INT16_MAX = 32767 well before the edge — so those tiles saturate to colour 3 (gold). When phase_f is strongly negative, all tiles saturate to INT16_MIN → colour 0 (indigo). The phase sweeps continuously, so the saturation boundary pulses in and out across the mandala.'],
  ['6-fold symmetry', 'Hex axial coordinates (q, r, s=−q−r) have intrinsic 6-fold rotational symmetry when |q|, |r|, |s| are sorted. Tiles that are rotations of each other in hexagonal space share the same (a, b, c) triple and therefore the same intensity, giving a kaleidoscope without any trigonometry.'],
];
---

<Base title="Saturating-Cast Kaleidoscope — bioHACK•NET" description="A 6-fold hex kaleidoscope on a Super Nintendo whose colours are determined by saturating float-to-int casts: fminf/fmaxf clamp the intensity to the int16 range, and the (int16_t) cast lowers to G_FPTOSI with a legalizer-inserted NaN guard. Compiler stress-test #77.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Saturating-Cast Kaleidoscope</h1>
      <a href="/snes/#cat-rendering" class="rp-cat-chip">Rendering & Graphics</a>
      <p class="rp-lede">
        A 6-fold hex kaleidoscope on a Super Nintendo whose colours are driven by <em>saturating float-to-int
        casts</em>: <code>fminf</code>/<code>fmaxf</code> clamp a float intensity into the int16 range, then
        <code>(int16_t)</code> truncates — with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a> legalizer at line 502 inserting a NaN
        guard automatically. Saturated outer tiles form crisp flat-colour plateaus; inner tiles show the
        colour gradient as phase sweeps. Compiler stress-test #77, the first demo to call
        <code>fminf</code>/<code>fmaxf</code>.
      </p>
    </header>

    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running the Saturating-Cast Kaleidoscope">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running — saturation boundary pulses through the mandala as phase sweeps.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        Each tile maps to a hex axial coordinate triple (q, r, s=−q−r); sorting the absolute values
        |q|,|r|,|s| folds the grid into the first sextant, giving 6-fold symmetry without trigonometry.
        A float intensity is then computed from the sorted triple and an advancing phase:
        <em>intensity = a²·200 − b²·50 + phase</em>. For large a (outer rings) the intensity exceeds the
        int16 range and saturates; for inner tiles the cast stays in-range and the 4 colour levels
        visible. As phase sweeps continuously, the saturation boundary pulses in and out.
      </p>
      <pre class="rp-code">{code}</pre>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against bsnes-jg and MAME.
        Hit <b>Verify fidelity</b> to reproduce the build gate's WRAM assert (gate CRC <code>0xC8CF</code> —
        16-phase × 8-tile rotating-XOR fold of sc_tile_color) live in this tab. No far
        pointers — <code>host == default == +mos-a16 == +mos-xy16</code>, <code>-verify</code> clean.</p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'satcast';
    window.BJG_BUST = bust;
    window.BJG_SELFCHECK = { off: 0x80, len: 2, want: 0xC8CF, frames: 500, label: 'satcast CRC' };
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-cat-chip {
    display: inline-block; margin-top: .5rem; padding: 3px 10px;
    font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: var(--ink-dim); background: var(--bg-soft, #1e2128);
    border: 1px solid var(--rule, #2e3138); border-radius: 4px;
    text-decoration: none; transition: border-color .15s, color .15s;
  }
  .rp-cat-chip:hover { border-color: var(--accent); color: var(--accent); }
  .rp-wrap { --rp-accent: var(--accent); max-width: 900px; margin-inline: auto; padding: 2.5rem 1.25rem 4rem; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400;
              text-transform: uppercase; letter-spacing: 0.04em; line-height: 1;
              font-size: clamp(2.2rem, 9vw, 3.5rem); margin: 0; color: var(--ink); }
  .rp-lede { margin: 1rem 0 0; color: var(--ink); opacity: .85; line-height: 1.65; }
  .rp-lede code, .rp-lede a { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-lede a:hover { text-decoration: underline; }
  .rp-lede em { font-style: italic; }
  .rp-player { max-width: 544px; margin: 2.25rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 6px; line-height: 0; border: 1px solid var(--rule); }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 'JetBrains Mono', ui-monospace, monospace; color: var(--ink-dim); }
  .rp-btn { margin-left: auto; background: transparent; color: var(--ink-dim); cursor: pointer; font-size: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            border: 1px solid var(--accent-soft); border-radius: 6px; padding: .4rem .85rem;
            transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px 'JetBrains Mono', ui-monospace, monospace; }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; color: var(--ink-dim); font-style: italic; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; color: var(--ink-dim); }
  .rp-doc { max-width: 42rem; margin: 3rem auto 0; color: var(--ink); line-height: 1.7; }
  .rp-doc h2 { font-size: 12px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase;
               color: #7dd3fc; margin: 2.25rem 0 .6rem; }
  .rp-doc p { margin: .4rem 0; }
  .rp-doc em { font-style: italic; }
  .rp-doc b { color: var(--ink); }
  .rp-doc code { font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--accent); }
  .rp-code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px;
             background: var(--bg-soft, #1e2128); color: var(--accent); padding: .75rem 1rem;
             border-radius: 6px; margin: .75rem 0; white-space: pre; overflow-x: auto; line-height: 1.6; }
  .rp-table { width: 100%; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table.rp-wide { max-width: 44rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .68rem; letter-spacing: .08em;
                 color: var(--ink-dim); padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid var(--rule); }
  .rp-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .85em; }
  .rp-foot { margin-top: 1.5rem; font-size: 13px; color: var(--ink-dim); }
</style>
