---
// /snes/truncstair — playable in-browser Truncation Staircase SNES demo.
// Compiler stress-test #83: G_FPTOSI/G_SITOFP (__fixsfsi/__floatsisf) as truncf-via-cast.
import Base from '../../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/truncstair.sfc', 'preview/truncstair.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

const code = `// "truncf(x)" without a libcall — floorf/ceilf/truncf are .unsupported() in the SDK.
int16_t q  = (int16_t)x_f;      // G_FPTOSI → __fixsfsi   (truncate toward zero)
float   qf = (float)q;          // G_SITOFP → __floatsisf (back to float)
float   diff = x_f - qf;        // G_FSUB   → __subsf3    (fractional remainder)

// floor = trunc, then correct downward for negative non-integers:
int16_t f = (x_f - (float)(int16_t)x_f < 0.0f) ? (int16_t)x_f - 1 : (int16_t)x_f;
// round = trunc(x ± 0.5):
int16_t r = (x_f >= 0.0f) ? (int16_t)(x_f + 0.5f) : (int16_t)(x_f - 0.5f);`;

const notes = [
  ['G_FPTOSI / G_SITOFP', 'The fundamental float↔integer conversion nodes. On the 65816 they lower to __fixsfsi (float→int, truncation toward zero) and __floatsisf (int→float) — soft-float library calls, since the CPU has no floating-point unit.'],
  ['the floorf/ceilf/truncf gap', 'The MOS SDK marks truncf, floorf, and ceilf as .unsupported() in the legalizer — calling them directly fails to link (no symbol exists). This demo shows the idiomatic workaround: (float)((int16_t)x) performs truncf inline via G_FPTOSI + G_SITOFP with no libcall, and floor/round are built from trunc plus a sign correction.'],
  ['trunc vs floor vs round', 'The three rounding modes agree on positive values but diverge on negatives: trunc(−0.75)=0, floor(−0.75)=−1, round(−0.75)=−1; trunc(−1.5)=−1, floor(−1.5)=−2, round(−1.5)=−2. The three bands make the divergence visible as the ramp scrolls through zero.'],
  ['what the differential caught', 'This demo\'s cross-emulator differential gate caught a real bug — a demo-side out-of-bounds write in the renderer (the round band drew one tile row past the 16-row canvas, overflowing the tile buffer and corrupting the result register). It surfaced only on bsnes-jg (whose power-on RAM is non-zero) and was masked on the zero-init emulator — the classic "reads uninitialized memory" signature. The compiler codegen was correct throughout; the fix was a bounds guard in the demo.'],
];
---

<Base title="Truncation Staircase — bioHACK•NET" description="Three bands comparing truncate / floor / round-toward-nearest on a scrolling ramp, built from __fixsfsi/__floatsisf (G_FPTOSI/G_SITOFP) — the truncf-via-cast idiom the SNES C toolchain uses because floorf/ceilf/truncf are unsupported. Compiler stress-test #83.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Truncation Staircase</h1>
      <a href="/snes/#cat-algorithms" class="rp-cat-chip">Algorithms &amp; Numeric</a>
      <p class="rp-lede">
        Three horizontal bands compare <em>truncate</em>, <em>floor</em>, and
        <em>round</em> applied to a scrolling linear ramp. All three are built
        from <code>(int16_t)x</code> / <code>(float)q</code> — the backend's
        <code>G_FPTOSI</code>/<code>G_SITOFP</code> (<code>__fixsfsi</code>/
        <code>__floatsisf</code>) — because <code>floorf</code>/<code>ceilf</code>/
        <code>truncf</code> are <code>.unsupported()</code> in the SNES SDK. Watch
        the three staircases diverge at the negative zero-crossing. Compiler
        stress-test #83.
      </p>
    </header>

    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Truncation Staircase">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
        <button id="fullscreen" class="rp-btn">Fullscreen</button>
      </div>
      <p class="rp-keys">Self-running — top=trunc · middle=floor · bottom=round, scrolling through zero.</p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen to focus, then watch. Tab away and it pauses.</p>
    </section>

    <section class="rp-doc">
      <h2>What it is</h2>
      <p>
        A linear ramp scrolls horizontally; each of the three bands quantizes it with a different
        rounding rule and plots the result as a staircase. On positive inputs the three agree; as
        the ramp crosses zero they split — truncation rounds toward zero, floor rounds down, and
        round-half goes to the nearest — so the negative half shows three distinct step patterns.
      </p>
      <pre class="rp-code">{code}</pre>
      <p>
        None of this uses a math-library rounding function: the SNES C toolchain has no
        <code>truncf</code>/<code>floorf</code>/<code>ceilf</code>, so the demo synthesizes them
        from integer casts (the soft-float <code>__fixsfsi</code>/<code>__floatsisf</code> calls)
        plus a sign correction — the same idiom real 65816 code must use.
      </p>

      <h2>Compiler stress-test</h2>
      <table class="rp-table rp-wide">
        <thead><tr><th>Item</th><th>What it exercises</th></tr></thead>
        <tbody>{notes.map(([n, d]) => (<tr><td class="rp-mono">{n}</td><td>{d}</td></tr>))}</tbody>
      </table>

      <p class="rp-foot">Written in C with the llvm-mos 65816 toolchain and verified against
        bsnes-jg and MAME. Hit <b>Verify fidelity</b> to reproduce the build gate's WRAM assert
        (rounding CRC <code>0x02CA</code> — a fold of 48 trunc/sitofp cycles) live in this tab.
        No far pointers — <code>host == default == +mos-a16 == +mos-xy16</code>,
        <code>-verify</code> clean.</p>
    </section>
  </main>
</Base>

<script is:inline define:vars={{ bust, appV }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = 'truncstair';
    window.BJG_BUST = bust;
    window.BJG_SELFCHECK = { off: 0x67, len: 2, want: 0x02CA, frames: 500, label: 'rounding CRC' };
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) { window.__bjgReg = true; document.addEventListener('astro:page-load', bootEmulator); }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

