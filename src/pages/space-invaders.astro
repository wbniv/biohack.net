---
// /space-invaders — playable in-browser Space Invaders (SNES) + instructions.
// Boots the shared bsnes-jg WASM player (public/play/app.js) on roms/space-invaders.sfc. Built from
// the snes-rom-page skill's page-template.astro, branded to biohack.net (dark + orange, Dune Rise).
//
// Cache-busting: hash each play/ asset at build time -> window.BJG_BUST; app.js appends "?v=<sha>"
// so the edge caches immutably yet a re-synced asset still gets a fresh URL.
import Base from '../layouts/Base.astro';
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';

const PLAY = 'public/play';
const BUST_ASSETS = [
  'app.js', 'cores/bsnes_jg.js', 'cores/bsnes_jg.wasm', 'cores/PROVENANCE.json',
  'roms/manifest.json', 'roms/space-invaders.sfc', 'preview/space-invaders.png',
];
const bust: Record<string, string> = {};
for (const a of BUST_ASSETS) {
  try { bust[a] = createHash('sha256').update(readFileSync(`${PLAY}/${a}`)).digest('hex').slice(0, 12); } catch {}
}
const appV = bust['app.js'] ?? '';

// In-browser keys (fixed by the player) -> Space Invaders actions.
const controls = [
  ['← →', 'Move the cannon'],
  ['Z / X / A', 'Fire'],
  ['Enter', 'Start — take over the demo'],
  ['Shift', 'Select — back to the attract demo'],
];
---

<Base title="Space Invaders — bioHACK•NET" description="Space Invaders for the Super Nintendo, written in C on an OOP rendering library and compiled with the llvm-mos 65816 toolchain — play it in your browser.">
  <main class="rp-wrap">

    <header class="rp-hero">
      <h1 class="rp-title">Space Invaders</h1>
      <p class="rp-lede">
        The arcade classic, running live on the Super Nintendo — a marching fleet of three alien
        kinds, falling bombs, destructible bunkers, a bonus UFO and a score/lives HUD, written in C on a small
        <strong>object-oriented rendering library</strong> (<code>snesgfx</code>) and compiled to a
        real <code>.sfc</code> ROM with the
        <a href="https://github.com/llvm-mos/llvm-mos">llvm-mos</a>-based 65816 toolchain. Sprites are
        hardware OAM objects; the art is <a href="https://github.com/alekmaul/pvsneslib">gfx4snes</a>
        tiles linked straight into ROM. It boots into a self-playing demo — press <b>Enter</b> to take
        over.
      </p>
    </header>

    <!-- emulator (centred) -->
    <section id="bjg-embed" class="rp-player" aria-label="Live SNES emulator running Space Invaders">
      <div class="rp-screen"><canvas id="screen" width="256" height="224" aria-label="SNES screen"></canvas></div>
      <div class="rp-row">
        <span id="status" class="rp-status">loading core…</span>
        <span id="checkresult" class="rp-badge"></span>
        <button id="verify" class="rp-btn" disabled>Verify fidelity</button>
      </div>
      <p class="rp-keys">
        <b>← →</b> move · <b>Z</b>/<b>X</b>/<b>A</b> fire · <b>Enter</b> play · <b>Shift</b> attract
      </p>
      <p id="banner" class="rp-banner"></p>
      <p class="rp-hint">Click the screen, then play. It self-plays until you press Enter — tab away and it pauses.</p>
    </section>

    <!-- instructions -->
    <section class="rp-doc">
      <h2>Controls</h2>
      <table class="rp-table">
        <thead><tr><th>Keys</th><th>Action</th></tr></thead>
        <tbody>{controls.map(([k, a]) => (<tr><td><kbd>{k}</kbd></td><td>{a}</td></tr>))}</tbody>
      </table>

      <h2>How it's built</h2>
      <p>
        The game is one C program on <code>snesgfx</code>, a header-only OOP-in-C library: a
        <code>Display</code> owns the boot sequence and a v-blank-gated DMA upload queue; a
        <code>SpriteSet</code> wraps the 544-byte OAM (hardware sprite) table; the fleet, player,
        bullets and UFO are plain typed objects drawn into it. No far pointers, so it builds in three
        compiler modes — default 8-bit, 16-bit accumulator (<code>+mos-a16</code>) and 16-bit index
        (<code>+mos-xy16</code>).
      </p>
      <h2>Verify fidelity</h2>
      <p>
        The whole game logic is a portable, deterministic simulation shared between the SNES ROM and a
        host program. The demo plays a fixed scripted run and folds the evolving game state into a
        CRC. <strong>Verify fidelity</strong> reruns that here in your tab and checks the CRC equals
        <code>0x9D57</code> — the same value asserted on the host and on two emulators (MAME and
        bsnes-jg) across all three compiler modes in the build gate. Press it to reproduce the
        differential check live.
      </p>
    </section>

  </main>
</Base>

<script is:inline define:vars={{ bust, appV, slug: 'space-invaders' }}>
  function bootEmulator() {
    if (!document.getElementById('bjg-embed')) return;
    if (window.__bjgStop) { try { window.__bjgStop(); } catch (e) {} }
    window.BJG_BASE = '/play/';
    window.BJG_DEFAULT_ROM = slug;
    window.BJG_BUST = bust;
    window.BsnesJg = undefined;
    window.__bjg = undefined;
    var old = document.getElementById('bjg-appjs');
    if (old) old.remove();
    var s = document.createElement('script');
    s.id = 'bjg-appjs';
    s.src = '/play/app.js' + (appV ? '?v=' + appV : '');
    document.body.appendChild(s);
  }
  if (!window.__bjgReg) {
    window.__bjgReg = true;
    document.addEventListener('astro:page-load', bootEmulator);
  }
  if (document.readyState !== 'loading') bootEmulator();
  else document.addEventListener('DOMContentLoaded', bootEmulator);
</script>

<style>
  .rp-wrap { --rp-accent: var(--accent, #c2410c); max-width: 900px; margin-inline: auto; padding: 2rem 1.25rem 4rem; color: inherit; }
  .rp-hero { max-width: 42rem; margin-inline: auto; text-align: center; }
  .rp-title { font-family: 'Dune Rise', 'Space Grotesk', system-ui, sans-serif; font-weight: 400; text-transform: uppercase; font-size: clamp(2rem, 7vw, 3.25rem); margin: 0; }
  .rp-lede { margin: .75rem 0 0; opacity: .85; line-height: 1.6; }

  .rp-player { max-width: 544px; margin: 2rem auto 0; }
  .rp-screen { width: 100%; background: #000; border-radius: 8px; line-height: 0; }
  .rp-screen canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
  .rp-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; margin-top: .85rem;
            font: 12px/1.4 ui-monospace, monospace; opacity: .8; }
  .rp-btn { margin-left: auto; background: transparent; color: inherit; cursor: pointer; font-size: 12px;
            border: 1px solid color-mix(in srgb, var(--rp-accent) 45%, transparent);
            border-radius: 8px; padding: .4rem .85rem; transition: border-color .15s, color .15s; }
  .rp-btn:hover:not(:disabled) { border-color: var(--rp-accent); color: var(--rp-accent); }
  .rp-btn:disabled { opacity: .45; cursor: not-allowed; }
  .rp-badge { font: 12px ui-monospace, monospace; }
  .rp-badge.running { color: var(--rp-accent); }
  .rp-badge.pass { background: #54d98c; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-badge.fail { background: #ff6b6b; color: #0c1116; font-weight: 600; padding: 2px 8px; border-radius: 5px; }
  .rp-keys { margin: .75rem 0 0; font-size: 11.5px; opacity: .75; }
  .rp-keys b { opacity: 1; font-weight: 600; }
  .rp-hint { margin: .5rem 0 0; font-size: 12px; opacity: .6; }
  .rp-banner { margin: .6rem 0 0; font-size: 12px; opacity: .75; }

  .rp-doc { max-width: 42rem; margin: 3rem auto 0; line-height: 1.65; }
  .rp-doc h2 { font-size: 1.5rem; margin: 2rem 0 .5rem; }
  .rp-table { width: 100%; max-width: 28rem; border-collapse: collapse; margin: .5rem 0 1rem; }
  .rp-table th { text-align: left; text-transform: uppercase; font-size: .72rem; letter-spacing: .08em;
                 opacity: .6; padding: .35rem .6rem; border-bottom: 1px solid currentColor; }
  .rp-table td { padding: .35rem .6rem; border-bottom: 1px solid color-mix(in srgb, currentColor 18%, transparent); }
  .rp-doc kbd { font: 600 .82em ui-monospace, monospace; border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
                border-radius: 4px; padding: .05em .4em; }
</style>
